# Telegram Drive – Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

API_ID=12345678
API_HASH=your_api_hash_here

# JWT secret (auto-generated if not set, but set in production)
JWT_SECRET=your_random_secret_here
JWT_EXPIRY_DAYS=7

# On Render, set this to your persistent disk mount path:
# APP_DATA_DIR=/var/data

# NVIDIA Build API (OpenAI-compatible, for Qwen3 Coder model)
NVIDIA_API_KEY=nvapi-your_key_here
